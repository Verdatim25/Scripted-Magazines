; This section basically copies the hand position and orientation of the ak74 pmc so we can seamlessly use the anims here instead for the left hand

	hands_orientation                = 0.011688, 0.003882, 0
	hands_orientation_16x9           = 0.011688, 0.003882, 0
	hands_position                   = 0.020726, -0.004787, -0.165
	hands_position_16x9              = 0.020726, -0.004787, -0.165
	
