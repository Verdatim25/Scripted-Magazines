	; hands_position                   = 0.001956, -0.0196347, -0.143979
	; hands_position_16x9              = 0.001956, -0.0196347, -0.143979
	
	aim_hud_offset_pos               = -0.086188, 0.034411, -0.06
	aim_hud_offset_pos_16x9          = -0.086188, 0.034411, -0.06
	aim_hud_offset_rot               = -6e-06, 0.000278, 0
	aim_hud_offset_rot_16x9          = -6e-06, 0.000278, 0

	aim_hud_offset_alt_pos           = -0.147928, -0.060316, -0.02
	aim_hud_offset_alt_pos_16x9      = -0.147928, -0.060316, -0.02
