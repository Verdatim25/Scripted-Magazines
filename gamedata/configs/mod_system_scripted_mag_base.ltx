; just some base stuff for certain animation sets
@[nikolas_ak_reanims]

; this section tells the script which bones to hide
s_magazine_hide_bones = magazin, magazin_empty

;=============================================================================
; this tells the script the position, rotation, scale and parent bone for the attachment FOR THIS SPECIFIC MAG BONE
; It goes  s_magazine_positions_[BONE_NAME] 
; so later if the mag bone name is say  mag  or  mag60  we need that name to be at the end
; DONT FORGET THIS WHEN ADDING STUFF!! 
;=============================================================================

s_magazine_positions_magazin = 0.001,0,0
s_magazine_rotations_magazin = 0,0,0
s_magazine_scale_magazin = 1
s_magazine_parent_bone_magazin = magazin

s_magazine_positions_magazin_empty = 0.001,0,0
s_magazine_rotations_magazin_empty = 0,0,0
s_magazine_scale_magazin_empty = 1
s_magazine_parent_bone_magazin_empty = magazin_empty

anm_reload_mag_swap_delay = 1.333
anm_reload_empty_mag_swap_delay = 1.333

;=============================================================================
